# ============================================================
# .gitignore — Workspace Automation System
# ============================================================

# ── Python bytecode ────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Virtual environments ──────────────────────────────────
venv/
.venv/
env/
.env/

# ── IDE / Editor ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ── OS generated ──────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Runtime / generated ───────────────────────────────────
logs/app.log
database/tasks.db
*.db-journal
*.db-wal
*.db-shm

# ── Distribution / packaging ─────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Legacy files (kept for migration reference only) ──────
# workspaces.json    ← uncomment after migration is verified
# logs.txt           ← old log format, replaced by logs/app.log
